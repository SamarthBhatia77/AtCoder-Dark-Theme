{
  "manifest_version": 3,
  "name": "AtCoder Aesthetic Dark Mode",
  "version": "1.0.0",
  "description": "A beautiful, handcrafted dark theme for AtCoder that preserves rating, syntax, and status colors.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://atcoder.jp/*"],
      "js": ["content.js"],
      "css": ["theme.css"],
      "run_at": "document_start"
    }
  ]
}
